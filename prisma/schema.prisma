generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// libSQL (Turso) is wire-compatible with SQLite — keep provider as sqlite,
// connect via @prisma/adapter-libsql at runtime (lib/db.ts).
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 워커가 manual sync 마다 거래소 잔고 환산 결과 1행 insert.
// Vercel page 는 latest 1행을 read.
model BalanceSnapshot {
  id           Int      @id @default(autoincrement())
  takenAt      DateTime @default(now())
  exchange     String   // upbit | bithumb
  totalKrw     Decimal  // exchange 합계 (cash + crypto)
  cashKrw      Decimal
  cryptoKrw    Decimal
  unpricedJson String   // [{currency, balance}] JSON 직렬화
  rawJson      String?  // 원본 응답 (디버그)

  @@index([exchange, takenAt])
}

// v0.1: enabled. v0.5+: price_snapshots / fx_rates 추가 활성화.
model Transaction {
  id          Int      @id @default(autoincrement())
  timestamp   DateTime
  source      String   // exchange | manual | csv
  exchange    String?  // upbit | bithumb | null
  externalId  String?  // 거래소 측 uuid — ingestion idempotency key
  assetClass  String   // crypto | stock | cash | loan | realestate
  assetSymbol String   // BTC, KRW, KOSPI:005930, ...
  side        String   // buy | sell | deposit | withdraw | interest | dividend
  qty         Decimal
  price       Decimal
  fee         Decimal  @default(0)
  currency    String   // KRW, USD, ...
  note        String?
  createdAt   DateTime @default(now())

  @@unique([source, exchange, externalId])
  @@index([assetSymbol, timestamp])
  @@index([source, exchange])
}

// 시점별 자산 가치 평가 + 멀티 거래소 / 외환 통합용. /sync 시 매번 보유
// 코인의 현재가가 1행씩 박힘. 미래에 "2024-06-01 시점 자산" 같은 retro 쿼리는
// (a) 그 시점 이전 transactions 으로 holdings 복원 (b) 그 시점 PriceSnapshot
// 으로 평가, 형태로 동작.
model PriceSnapshot {
  id      Int      @id @default(autoincrement())
  takenAt DateTime
  market  String   // KRW-BTC, USDT-BTC (Binance), USD-BTC 등
  price   Decimal
  source  String   // upbit | bithumb | binance | mexc | manual

  @@index([market, takenAt])
  @@index([source, takenAt])
}

// USD/KRW 같은 환율 history. fx fetch 마다 캐시 hit 가 아닐 때 1행씩.
// Binance/MEXC USDT 자산을 KRW 환산할 때 시점 환율 조회용.
model FxRate {
  id      Int      @id @default(autoincrement())
  takenAt DateTime
  base    String   // USD, USDT
  quote   String   // KRW
  rate    Decimal
  source  String   // bok | frankfurter | exchange-derived

  @@index([base, quote, takenAt])
}
