# Turso (libSQL) — Vercel Marketplace integration 으로 자동 provisioning 권장.
# 로컬 dev: turso db create moa-dev && turso db tokens create moa-dev
TURSO_DATABASE_URL="libsql://moa-<your-org>.turso.io"
TURSO_AUTH_TOKEN=""

# Fixie (Vercel Marketplace integration) — outbound proxy.
# Marketplace install 후 Vercel env 에 자동 등록됨. 로컬 dev 에서 키 사용하려면 Fixie dashboard 의 URL 복사.
FIXIE_URL="http://fixie:<your-token>@criterium.usefixie.com:80"

# 업비트 read-only API key (https://upbit.com/mypage/open_api_management)
# 화이트리스트 IP = Fixie 가 발급한 static IPs (Fixie dashboard 에서 확인)
UPBIT_ACCESS_KEY=""
UPBIT_SECRET_KEY=""

# 빗썸 read-only API key (Day 2)
BITHUMB_ACCESS_KEY=""
BITHUMB_SECRET_KEY=""

# Basic auth — Vercel Hobby 의 HTTPS 위에 단일 비밀번호 게이트
BASIC_AUTH_PASSWORD="change-me"
