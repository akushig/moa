# Turso (libSQL) — Vercel Marketplace integration 으로 자동 provisioning.
# 로컬 dev: Vercel 대시보드 → Project → Settings → Environment Variables 에서 복사.
TURSO_DATABASE_URL="libsql://<db>-<org>.turso.io"
TURSO_AUTH_TOKEN=""

# 업비트 read-only API key (https://upbit.com/mypage/open_api_management)
# 화이트리스트 IP = GCP Reserved External IPv4 (워커 VM)
UPBIT_ACCESS_KEY=""
UPBIT_SECRET_KEY=""

# 빗썸 read-only API key (잔고조회 권한, IP 화이트리스트 동일)
BITHUMB_ACCESS_KEY=""
BITHUMB_SECRET_KEY=""

# Basic auth — Vercel Hobby 의 HTTPS 위에 단일 비밀번호 게이트 (Vercel app 만 사용)
BASIC_AUTH_PASSWORD="change-me"

# 워커 (GCP VM) 호출용. Vercel app → 워커 sync proxy.
# WORKER_SHARED_SECRET 은 워커 setup 시 자동 생성/출력되는 값을 그대로 박는다.
WORKER_URL="https://<reserved-ip>.sslip.io"
WORKER_SHARED_SECRET=""
